// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CREDIT_CARD
  PAYPAL
  STRIPE
}

model Business {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  logo        String?
  defaultLang String           @default("en")
  users       User[]
  roles       Role[]
  pages       Page[]
  services    Service[]
  categories  Category[]
  products    Product[]
  orders      Order[]
  contacts    ContactMessage[]
  carts       Cart[]
  settings    Settings?
  coupons     Coupon[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  businessId  Int
  name        String
  description String?
  users       User[]
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model User {
  id                 Int       @id @default(autoincrement())
  businessId         Int
  roleId             Int
  name               String
  email              String
  password           String
  isActive           Boolean   @default(true)
  passwordResetToken String?
  lastLoginAt        DateTime?
  cart               Cart?
  orders             Order[]
  business           Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role               Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([businessId, email]) // email unique per business
  @@index([businessId])
}

model Settings {
  id             Int      @id @default(autoincrement())
  businessId     Int      @unique
  seoTitle       String?
  seoDescription String?
  currency       String   @default("USD")
  theme          String   @default("default")
  cacheTTL       Int      @default(3600) // seconds
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

//////////////////////////
// Pages & Services
//////////////////////////

model Page {
  id           Int               @id @default(autoincrement())
  businessId   Int
  slug         String
  isPublished  Boolean           @default(true)
  isDeleted    Boolean           @default(false)
  translations PageTranslation[]
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, slug])
  @@index([businessId])
}

model PageTranslation {
  id              Int     @id @default(autoincrement())
  pageId          Int
  lang            String
  title           String
  body            String  @db.Text
  metaTitle       String?
  metaDescription String?
  page            Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, lang])
}

model Service {
  id           Int                  @id @default(autoincrement())
  businessId   Int
  icon         String?
  isActive     Boolean              @default(true)
  isDeleted    Boolean              @default(false)
  translations ServiceTranslation[]
  business     Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model ServiceTranslation {
  id          Int     @id @default(autoincrement())
  serviceId   Int
  lang        String
  title       String
  description String  @db.Text
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, lang])
}

//////////////////////////
// E-Commerce Domain
//////////////////////////

model Category {
  id           Int                   @id @default(autoincrement())
  businessId   Int
  parentId     Int?
  isActive     Boolean               @default(true)
  isDeleted    Boolean               @default(false)
  translations CategoryTranslation[]
  products     Product[]
  business     Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent       Category?             @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]            @relation("CategoryParent")

  @@index([businessId])
}

model CategoryTranslation {
  id         Int      @id @default(autoincrement())
  categoryId Int
  lang       String
  name       String
  slug       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
}

model Product {
  id           Int                  @id @default(autoincrement())
  businessId   Int
  categoryId   Int
  price        Float
  stock        Int
  sku          String
  isActive     Boolean              @default(true)
  isDeleted    Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  translations ProductTranslation[]
  images       ProductImage[]
  variants     ProductVariant[]
  category     Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  business     Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@index([businessId])
  @@index([categoryId])
}

model ProductTranslation {
  id          Int     @id @default(autoincrement())
  productId   Int
  lang        String
  name        String
  description String  @db.Text
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, lang])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  altText   String?
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int
  name      String
  sku       String?
  price     Float?
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Coupon {
  id              Int       @id @default(autoincrement())
  businessId      Int
  code            String
  discountPercent Float?
  discountAmount  Float?
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@unique([businessId, code])
  @@index([businessId])
}

//////////////////////////
// Cart & Orders
//////////////////////////

model Cart {
  id         String     @id @default(uuid())
  userId     Int?       @unique
  businessId Int
  items      CartItem[]
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    String
  productId Int
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id              Int           @id @default(autoincrement())
  businessId      Int
  userId          Int?
  orderNumber     String        @unique
  totalAmount     Float
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH_ON_DELIVERY)
  transactionId   String?
  shippingAddress String?       @db.Text
  billingAddress  String?       @db.Text
  customerEmail   String?
  customerName    String?
  customerPhone   String?
  couponId        Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           OrderItem[]
  user            User?         @relation(fields: [userId], references: [id], onDelete: Restrict)
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  orderId       Int
  productId     Int
  quantity      Int
  priceSnapshot Float
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId])
  @@map("order_items")
}

//////////////////////////
// Contact
//////////////////////////

model ContactMessage {
  id         Int      @id @default(autoincrement())
  businessId Int
  name       String
  email      String
  message    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}
